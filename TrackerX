            return
            
        idx = int(sel[0])
        rows = read_expenses()
        old = rows[idx]

        win = tk.Toplevel(self.root)
        win.title("Update Expense")
        win.geometry("420x220")

        tk.Label(win, text="Date (YYYY-MM-DD)").grid(row=0, column=0, padx=6, pady=6, sticky="w")
