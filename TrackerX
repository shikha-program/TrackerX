    # ----------------- Enhanced GUI Methods -----------------
    def on_category_keyrelease(self, event):
        typed = self.category_var.get()
        if typed:
            self.entry_category['values'] = [cat for cat in self.categories if typed.lower() in cat.lower()]
        else:
            self.entry_category['values'] = self.categories
            
    def refresh_data(self):
        clear_cache()
        self.categories = get_all_categories()
        self.refresh_tree()
        self.update_dashboard()
        self.update_budget_display()
        self.check_budgets()
        
    def check_budgets(self):
        alerts = check_budget_alerts()
        if alerts:
            alert_text = "\n".join(alerts)
            self.alert_label.config(text=alert_text)
        else:
            self.alert_label.config(text="All budgets are within limits ✅")
            
    def update_budget_display(self):
        budgets = SETTINGS.get('budgets', {})
        self.budget_text.delete(1.0, tk.END)
        
        if not budgets:
            self.budget_text.insert(1.0, "No budgets set yet.\nUse the form above to set budgets.")
            return
            
        self.budget_text.insert(1.0, "Current Budgets:\n\n")
        for category, amount in budgets.items():
            self.budget_text.insert(tk.END, f"• {category}: ₹{amount:.2f}\n")
            
    def set_budget(self):
        category = self.cat_budget_combo.get().strip()
        amount_str = self.cat_budget_amount.get().strip()
        
        if not amount_str:
            messagebox.showwarning("Missing", "Please enter budget amount")
            return
            
        try:
            amount = float(amount_str)
        except ValueError:
            messagebox.showerror("Invalid", "Amount must be a number")
            return
            
        if category:
            # Category-specific budget
            SETTINGS['budgets'][category] = amount
        else:
            # Overall budget
            SETTINGS['budgets']['overall'] = amount
            
        save_settings(SETTINGS)
        self.update_budget_display()
        self.check_budgets()
        messagebox.showinfo("Success", "Budget set successfully!")
        
    def save_settings(self):
        SETTINGS['theme'] = self.theme_var.get()
        SETTINGS['default_currency'] = self.currency_var.get()
        SETTINGS['auto_backup'] = self.auto_backup_var.get()
        save_settings(SETTINGS)
        messagebox.showinfo("Settings", "Settings saved successfully!")
        
    def safe_exit(self):
        if SETTINGS.get('auto_backup', True):
            self.auto_backup()
        self.root.quit()
        
    def auto_backup(self):
        rows = read_expenses()
        if rows:
