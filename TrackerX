            self.ax1.pie(cat_totals.values(), labels=cat_totals.keys(), autopct='%1.1f%%', startangle=90)
            self.ax1.set_title('Spending by Category')
            
        # Bar chart for monthly spending
        monthly_totals = totals_by_month(rows, 6)
        if monthly_totals:
            months = list(monthly_totals.keys())
            amounts = list(monthly_totals.values())
            self.ax2.bar(months, amounts, color='skyblue')
            self.ax2.set_title('Last 6 Months')
            self.ax2.tick_params(axis='x', rotation=45)
            
        self.canvas.draw()
        
