    def refresh_tree(self, filter_rows=None):
        for item in self.tree.get_children():
            self.tree.delete(item)
        rows = filter_rows if filter_rows is not None else read_expenses()
        for i, r in enumerate(rows):
            self.tree.insert("", "end", iid=str(i), values=r)
            
    def clear_entry_fields(self):
        self.entry_category.delete(0, tk.END)
        self.entry_description.delete(0, tk.END)
        self.entry_notes.delete(0, tk.END)
        self.entry_amount.delete(0, tk.END)
        self.entry_date.delete(0, tk.END)
        self.entry_date.insert(0, datetime.now().strftime("%Y-%m-%d"))
        
    def add_expense_gui(self):
        date = self.entry_date.get().strip()
        if not date:
            date = datetime.now().strftime("%Y-%m-%d")
            
        cat = self.entry_category.get().strip()
        desc = self.entry_description.get().strip()
        notes = self.entry_notes.get().strip()
        amt = self.entry_amount.get().strip()
        
        errors = validate_expense_data(date, cat, desc, amt)
        if errors:
            messagebox.showerror("Validation Error", "\n".join(errors))
            return
            
        try:
            amt_f = float(amt)
        except ValueError:
            messagebox.showerror("Invalid Amount", "Amount must be a number")
            return
            
        row = [date, cat, desc, notes, f"{amt_f:.2f}"]
        append_expense(row)
        self.refresh_data()
