                current_rows = read_expenses()
                current_rows.extend(imported_rows)
                write_expenses(current_rows)
                self.refresh_data()
                messagebox.showinfo("Success", f"Imported {len(imported_rows)} expenses successfully!")
                
        except Exception as e:
            messagebox.showerror("Import Error", f"Failed to import: {str(e)}")
            
