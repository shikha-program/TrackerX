# ----------------- Enhanced Helper Functions -----------------
def safe_file_operation(func):
    def wrapper(*args, **kwargs):
        try:
            return func(*args, **kwargs)
        except Exception as e:
            logging.error(f"Error in {func.__name__}: {str(e)}")
            messagebox.showerror("Error", f"Operation failed: {str(e)}")
            return None
    return wrapper

@safe_file_operation
def read_expenses():
    rows = []
    try:
        with open(DATA_FILE, newline="", encoding='utf-8') as f:
            reader = csv.reader(f)
            header = next(reader, None)
            for r in reader:
                if not r or len(r) < 5:
                    continue
                rows.append([r[0], r[1], r[2], r[3], r[4]])
    except FileNotFoundError:
        return []
    return rows

@safe_file_operation
def write_expenses(rows):
    with open(DATA_FILE, "w", newline="", encoding='utf-8') as f:
        writer = csv.writer(f)
        writer.writerow(["Date", "Category", "Description", "Notes", "Amount"])
        writer.writerows(rows)

@safe_file_operation
def append_expense(row):
    with open(DATA_FILE, "a", newline="", encoding='utf-8') as f:
        writer = csv.writer(f)
        writer.writerow(row)

def validate_expense_data(date, category, description, amount):
    errors = []
    if not validate_date_str(date):
        errors.append("Invalid date format (YYYY-MM-DD)")
    if not category.strip():
        errors.append("Category is required")
    if not description.strip():
        errors.append("Description is required")
    try:
        float(amount)
    except ValueError:
        errors.append("Amount must be a valid number")
    return errors

def validate_date_str(datestr):
    try:
        datetime.strptime(datestr, "%Y-%m-%d")
        return True
    except:
        return False

@lru_cache(maxsize=128)
def get_cached_expenses():
    return read_expenses()

def clear_cache():
    get_cached_expenses.cache_clear()

def totals_by_category(rows):
    d = defaultdict(float)
    for r in rows:
        try:
            d[r[1]] += float(r[4])
        except:
            pass
    return dict(d)

def totals_by_month(rows, months=6):
    now = datetime.now()
    month_map = OrderedDict()
    for i in reversed(range(months)):
        m = now - timedelta(days=now.day-1) - timedelta(days=30*i)
        key = m.strftime("%Y-%m")
        month_map[key] = 0.0
    for r in rows:
        try:
            dt = datetime.strptime(r[0], "%Y-%m-%d")
            key = dt.strftime("%Y-%m")
            if key in month_map:
                month_map[key] += float(r[4])
        except:
            pass
    return month_map

def top_n_categories(rows, n=3):
    t = totals_by_category(rows)
    sorted_cats = sorted(t.items(), key=lambda x: x[1], reverse=True)
    return sorted_cats[:n]

def get_all_categories():
    rows = read_expenses()
    return sorted(list(set(r[1] for r in rows if r[1].strip())))

# -------------- Budget Functions -----------------
def check_budget_alerts():
    rows = read_expenses()
    current_month = datetime.now().strftime("%Y-%m")
    monthly_total = 0.0
    category_totals = defaultdict(float)
    
    for r in rows:
        if r[0].startswith(current_month):
            try:
                amount = float(r[4])
                monthly_total += amount
                category_totals[r[1]] += amount
            except:
                pass
    
    alerts = []
    budgets = SETTINGS.get('budgets', {})
    
    # Check overall budget
    overall_budget = budgets.get('overall')
    if overall_budget and monthly_total > overall_budget:
        alerts.append(f"⚠️ Over overall budget! (₹{monthly_total:.2f} / ₹{overall_budget:.2f})")
    
    # Check category budgets
    for category, budget in budgets.items():
        if category != 'overall' and category_totals[category] > budget:
            alerts.append(f"⚠️ Over {category} budget! (₹{category_totals[category]:.2f} / ₹{budget:.2f})")
    
    return alerts

# -------------- SQLite & JSON Backup -----------------
@safe_file_operation
def backup_to_sqlite(rows):
    conn = sqlite3.connect(DB_FILE)
    cur = conn.cursor()
    cur.execute("""CREATE TABLE IF NOT EXISTS expenses (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    date TEXT, category TEXT, description TEXT, notes TEXT, amount REAL
                )""")
    cur.execute("DELETE FROM expenses")
    for r in rows:
        try:
            amount = float(r[4])
        except:
            amount = 0.0
        cur.execute("INSERT INTO expenses (date, category, description, notes, amount) VALUES (?, ?, ?, ?, ?)",
                    (r[0], r[1], r[2], r[3], amount))
    conn.commit()
    conn.close()

@safe_file_operation
def backup_to_json(rows):
    fname = datetime.now().strftime("backups_json/backup_%Y%m%d_%H%M%S.json")
    with open(fname, "w", encoding="utf-8") as f:
        json.dump([{"date": r[0], "category": r[1], "description": r[2], "notes": r[3], "amount": r[4]} for r in rows], f, indent=2)
    return fname

