# Load settings
def load_settings():
    default_settings = {
        "theme": "light",
        "default_currency": "₹",
        "auto_backup": True,
        "budgets": {},
        "recurring_expenses": []
    }
    try:
        with open(SETTINGS_FILE, 'r') as f:
            return {**default_settings, **json.load(f)}
    except FileNotFoundError:
        return default_settings

def save_settings(settings):
    with open(SETTINGS_FILE, 'w') as f:
        json.dump(settings, f, indent=2)

# Global settings
