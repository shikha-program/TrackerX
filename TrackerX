    def search_filter(self):
        keyword = self.search_entry.get().strip().lower()
        cat_filter = self.filter_cat_entry.get().strip().lower()
        date_from = self.filter_from_entry.get().strip()
        date_to = self.filter_to_entry.get().strip()

        rows = read_expenses()
        results = []
        for r in rows:
            date_ok = True
            if date_from:
                if not validate_date_str(date_from):
                    messagebox.showerror("Invalid Date", "Date From must be YYYY-MM-DD")
                    return
                if datetime.strptime(r[0], "%Y-%m-%d") < datetime.strptime(date_from, "%Y-%m-%d"):
                    date_ok = False
            if date_to:
                if not validate_date_str(date_to):
                    messagebox.showerror("Invalid Date", "Date To must be YYYY-MM-DD")
                    return
                if datetime.strptime(r[0], "%Y-%m-%d") > datetime.strptime(date_to, "%Y-%m-%d"):
                    date_ok = False
            if not date_ok:
                continue

            text_blob = " ".join([r[1], r[2], r[3]]).lower()
            if keyword and keyword not in text_blob:
                continue
            if cat_filter and cat_filter != r[1].lower():
                continue
            results.append(r)

        self.refresh_tree(filter_rows=results)
        
    def reset_filters(self):
        self.search_entry.delete(0, tk.END)
        self.filter_cat_entry.delete(0, tk.END)
        self.filter_from_entry.delete(0, tk.END)
        self.filter_to_entry.delete(0, tk.END)
        self.refresh_tree()
        
    def update_dashboard(self):
        rows = read_expenses()
        currency = SETTINGS.get('default_currency', '₹')
        
        # Current month total
        now = datetime.now()
        month_str = now.strftime("%Y-%m")
        total_month = 0.0
        for r in rows:
            try:
                if r[0].startswith(month_str):
                    total_month += float(r[4])
            except:
                pass
        self.label_total_val.config(text=f"{currency}{total_month:.2f}")

        # Top categories
        top = top_n_categories(rows, n=3)
        txt = "\n".join([f"{i+1}. {c} — {currency}{amt:.2f}" for i, (c, amt) in enumerate(top)]) if top else "No data"
        self.label_topcats_val.config(text=txt)

        # Top 3 items
        sorted_items = sorted(rows, key=lambda x: float(x[4]) if x[4] else 0, reverse=True)[:3]
        items_txt = "\n".join([f"{it[0]} | {it[1]} | {currency}{it[4]}" for it in sorted_items]) if sorted_items else "No data"
        self.label_topitems_val.config(text=items_txt)

        # Insight
        this_month_total = 0.0
        last_month_total = 0.0
        try:
            for r in rows:
                dt = datetime.strptime(r[0], "%Y-%m-%d")
                if dt.strftime("%Y-%m") == now.strftime("%Y-%m"):
                    this_month_total += float(r[4])
                last_month = (now.replace(day=1) - timedelta(days=1))
                if dt.strftime("%Y-%m") == last_month.strftime("%Y-%m"):
                    last_month_total += float(r[4])
            if last_month_total == 0:
                insight = "No data for last month to compare."
            else:
                diff = this_month_total - last_month_total
                perc = (diff / last_month_total) * 100
                if diff > 0:
                    insight = f"Spending ↑ {abs(perc):.1f}% vs last month (spent {currency}{diff:.2f} more)."
                elif diff < 0:
                    insight = f"Spending ↓ {abs(perc):.1f}% vs last month (saved {currency}{abs(diff):.2f})."
                else:
                    insight = "Spending same as last month."
        except Exception as e:
            insight = "Not enough data to generate insight."
        self.label_insight_val.config(text=insight)
        
        # Update mini charts
        self.update_mini_charts(rows)
        
    def update_mini_charts(self, rows):
        # Clear previous plots
        self.ax1.clear()
        self.ax2.clear()
        
        # Pie chart for categories
